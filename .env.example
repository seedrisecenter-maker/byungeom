# Copy to .env and fill in values
# Never commit .env to git

# Required
ADMIN_SECRET=replace-with-a-strong-secret-string

# Optional — omit the ones you don't have
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional — defaults to ./byungeom_api.db
# DB_PATH=/data/byungeom_api.db

# Optional — defaults to 8000
# PORT=8000
